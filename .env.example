# ─── Database ───────────────────────────────────────────
DATABASE_URL="postgresql://autosocial:autosocial@localhost:5432/autosocial"

# ─── Redis ──────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── OpenAI (captions, hashtags, Whisper transcription) ──
OPENAI_API_KEY="sk-..."

# ─── Storage (Cloudflare R2 / S3-compatible) ─────────────
# For local dev these point at the bundled MinIO container.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="auto"
S3_ACCESS_KEY_ID="autosocial"
S3_SECRET_ACCESS_KEY="autosocial123"
S3_BUCKET_NAME="autosocial-videos"
S3_PUBLIC_URL="http://localhost:9000/autosocial-videos"
S3_FORCE_PATH_STYLE="true"

# ─── Social Media APIs ───────────────────────────────────
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# ─── App Config ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Monitoring (optional) ───────────────────────────────
SENTRY_DSN=""
