# ─── Database ───────────────────────────────────────────
DATABASE_URL="postgresql://autosocial:autosocial@localhost:5432/autosocial"

# ─── Redis ──────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── AI provider (captions, hashtags, transcription) ─────
# Priority: GROQ_API_KEY, then OPENAI_API_KEY, else deterministic mock output.
#
# Recommended for dev/demo: GROQ — free, no credit card, OpenAI-compatible.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=""
# Optional overrides (sensible defaults are used):
# GROQ_CHAT_MODEL="llama-3.3-70b-versatile"
# GROQ_TRANSCRIBE_MODEL="whisper-large-v3-turbo"

# Production quality alternative:
OPENAI_API_KEY="sk-..."

# ─── Storage (Cloudflare R2 / S3-compatible) ─────────────
# For local dev these point at the bundled MinIO container.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="auto"
S3_ACCESS_KEY_ID="autosocial"
S3_SECRET_ACCESS_KEY="autosocial123"
S3_BUCKET_NAME="autosocial-videos"
S3_PUBLIC_URL="http://localhost:9000/autosocial-videos"
S3_FORCE_PATH_STYLE="true"

# ─── Social Media APIs ───────────────────────────────────
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
# YouTube = live integration (Google OAuth 2.0 + YouTube Data API v3).
#   1. https://console.cloud.google.com → new project
#   2. Enable "YouTube Data API v3"
#   3. Create an OAuth 2.0 Client ID (Web application)
#   4. Authorized redirect URI: http://localhost:3000/api/social/youtube/callback
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
# Privacy of uploaded videos: private (default, safe) | unlisted | public
YOUTUBE_PRIVACY_STATUS="private"
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# ─── App Config ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Monitoring (optional) ───────────────────────────────
SENTRY_DSN=""
